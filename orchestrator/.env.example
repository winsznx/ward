# --- CROO (bare origin; WS auth is a ?key= query param — ground truth) ---
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
BASE_RPC_URL=https://mainnet.base.org
# Ward's agent SDK key (one WebSocket per key). Fund this agent's AA wallet with USDC.
CROO_SDK_KEY=croo_sk_replace_me

# --- Firewall judge (required: pattern-only over-quarantines descriptive audit reports) ---
GROQ_API_KEY=gsk_replace_me

# --- The human's DD request (INTAKE) ---
WARD_DD_TARGET=0x833589fcd6edb6e08f4c7c32d4f71b54bda02913
WARD_DD_REQUEST=Should I ape this token? Vet ownership, mint authority, liquidity, and sentiment.
WARD_DD_CHAIN=base

# --- Supplier registry ---
# negotiate targets a SERVICE GUID (serviceId) — verified live: the wire body is
# { serviceId, requirements: JSON-string }; agentId/serviceIndex are NOT wire fields (agentId is kept
# only for the counterparty/dominance identity). The seeds (attestr-risk, remi-sentiment) ship
# DISABLED because their service GUIDs are truncated in the registry note — fill the real serviceId
# from the agent page and enable via WARD_REGISTRY_JSON.
#
# Add suppliers via WARD_REGISTRY_JSON (a JSON array). External must DOMINATE supply (§10) by DISTINCT
# agentId — the planner holds out least-reliable friendly dimensions to keep external the majority.
# Each entry: { id, label, agentId, serviceId, category, cluster, requirementsTemplate, priceCeiling,
# reliability }. requirementsTemplate is a type-exact OBJECT (it's JSON-stringified for the wire);
# {{target}}/{{chain}} are substituted inside its string values.
#
# WARD_REGISTRY_JSON=[
#   {"id":"attestr-risk","label":"Attestr","agentId":"20ba0841-8411-4ee7-960e-5b1d376943d3","serviceId":"<real-service-guid>","category":"audit","cluster":"external","requirementsTemplate":{"tokenAddress":"{{target}}","chain":"{{chain}}"},"priceCeiling":0.05,"reliability":0.5},
#   {"id":"friendly-liquidity","label":"LiquidityDepth","agentId":"0x...","serviceId":"<real-service-guid>","category":"liquidity","cluster":"friendly","requirementsTemplate":{"token":"{{target}}"},"priceCeiling":0.02,"reliability":0.9}
# ]
#
# Disable specific suppliers by id (comma-separated):
# WARD_DISABLE_SUPPLIERS=remi-sentiment

# --- Optional: complete a real H2A order (the human hired Ward). Omit for operator/console mode. ---
# WARD_HUMAN_ORDER_ID=ord_...

# --- Optional tunables (ms) ---
# WARD_ACCEPT_TIMEOUT_MS=90000     # liveness window: no OrderCreated within this -> supplier dead -> alternate
# WARD_SLA_TIMEOUT_MS=480000       # per-order delivery window
# WARD_FANOUT_BUDGET_MS=1500000    # aggregate budget across the whole fan-out (one slow supplier can't hang it)
# DEBUG=1
