# --- CROO endpoints (shared by both agents) ---
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
BASE_RPC_URL=https://mainnet.base.org

# --- Per-agent SDK keys (one WebSocket per key — code 1008 if a key is doubled) ---
# Issued from the CROO Dashboard, format: croo_sk_...
# These belong to two DISTINCT agents on separate AA wallets.
CROO_SDK_KEY_PROVIDER=croo_sk_replace_me_provider
CROO_SDK_KEY_REQUESTER=croo_sk_replace_me_requester

# --- Requester target ---
# The serviceId the requester negotiates against. For this smoke test this is
# the provider agent's own service (the echo service it answers with {"echo":"ok"}).
CROO_TARGET_SERVICE_ID=svc_replace_me

# --- Optional ---
# DEBUG=1   # surface SDK debug logs (HTTP URLs, reconnect backoff)
